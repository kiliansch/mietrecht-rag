# Postgres connection (psycopg3 DSN). Matches docker-compose.yml defaults.
# Local dev: localhost. Inside docker compose the backend overrides the host to `db`.
DATABASE_URL=postgresql://mietrecht:mietrecht@localhost:5432/mietrecht

# Open Legal Data API key, used only by fetch_legal_data.py (statute/source fetching).
OLDP_API_KEY=

# OpenRouter API key, used for chat + embedding models (OpenAI-compatible endpoint).
OPENAI_API_KEY=sk-or-...

# --- API / frontend (FastAPI + React) ---
# HS256 signing secret for session JWTs. Empty = login disabled (503).
# Generate one with: openssl rand -hex 32
AUTH_SECRET=
# Session token lifetime in hours.
AUTH_TOKEN_TTL_HOURS=72
# Predefined admin account, seeded by `main.py setup-db` (min. 8 characters password).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Comma-separated browser origins allowed by CORS (default: the Vite dev server).
CORS_ORIGINS=http://localhost:5173
# Max contract-upload size in bytes (default 10 MB).
MAX_UPLOAD_BYTES=10485760

# Optional: LangSmith tracing.
LANGSMITH_TRACING=false
LANGSMITH_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mietrecht-rag
